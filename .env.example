# Public URL of the deployed Google Apps Script web app that receives
# contact form submissions and emails them to office@monsterprojectgroup.com.
#
# How to get this URL:
#   1. Open https://script.google.com (signed in as office@monsterprojectgroup.com)
#   2. New project -> paste the contents of google-apps-script/Code.gs
#   3. Deploy -> New deployment -> Type "Web app"
#        Execute as: Me (office@monsterprojectgroup.com)
#        Who has access: Anyone
#   4. Copy the resulting "Web app URL" into the line below.
#
# Note: The variable MUST start with VITE_ so Vite exposes it to the browser.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec
